{
  "name": "@gainforest/atproto-mutations-next",
  "version": "0.0.1",
  "description": "ATProto mutations for Next.js — tRPC router, server utilities, and typed client namespace.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "source": "./src/server/index.ts",
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./trpc": {
      "source": "./src/trpc/index.ts",
      "types": "./dist/trpc.d.ts",
      "import": "./dist/trpc.js",
      "require": "./dist/trpc.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "server": ["dist/server.d.ts"],
      "trpc": ["dist/trpc.d.ts"]
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/api": "0.19.0",
    "@gainforest/atproto-auth-next": "workspace:*",
    "@gainforest/atproto-mutations-core": "workspace:*",
    "@gainforest/internal-utils": "workspace:*",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "effect": "^3.19.19",
    "superjson": "^2.2.1"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "next": ">=14.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
