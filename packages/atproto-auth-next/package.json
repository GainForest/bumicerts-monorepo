{
  "name": "@gainforest/atproto-auth-next",
  "version": "0.0.1",
  "description": "ATProto OAuth authentication for Next.js — iron-session cookies, Supabase stores, agent construction.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./stores": {
      "types": "./dist/stores.d.ts",
      "import": "./dist/stores.js",
      "require": "./dist/stores.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "server": ["dist/server.d.ts"],
      "stores": ["dist/stores.d.ts"],
      "client": ["dist/client.d.ts"]
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@atproto/api": "^0.13.17",
    "@atproto/oauth-client-node": "^0.3.9",
    "iron-session": "^8.0.4"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.93.2",
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
