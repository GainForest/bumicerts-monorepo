{
  "name": "@gainforest/bumicerts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "graphql:schema": "gql.tada generate-schema $NEXT_PUBLIC_INDEXER_URL --output ./graphql/schema.graphql --header 'ngrok-skip-browser-warning: true'",
    "graphql:types": "gql.tada generate-output --tsconfig ./tsconfig.json",
    "graphql:codegen": "bun run graphql:schema && bun run graphql:types",
    "init-marketplace-route": "bun run scripts/init-marketplace-route.ts",
    "test:e2e": "tsc --project e2e/tsconfig.e2e.json && bunx cucumber-js --config e2e/cucumber.mjs",
    "test:e2e:headless": "E2E_HEADLESS=true tsc --project e2e/tsconfig.e2e.json && bunx cucumber-js --config e2e/cucumber.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@0no-co/graphqlsp": "^1.15.2",
    "@aws-sdk/client-s3": "^3.997.0",
    "@base-ui/react": "^1.2.0",
    "@gainforest/atproto-auth-next": "workspace:*",
    "@gainforest/atproto-mutations-next": "workspace:*",
    "@gainforest/leaflet-react": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@react-email/render": "^2.0.4",
    "@supabase/supabase-js": "2.97.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "blo": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "extract-colors": "^4.2.1",
    "framer-motion": "^12.34.3",
    "gql.tada": "^1.9.0",
    "graphql": "^16.13.0",
    "graphql-request": "^7.4.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-circular-progressbar": "^2.2.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-error-boundary": "^6.1.1",
    "recharts": "^3.8.1",
    "resend": "^6.9.2",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-local-storage": "^3.0.0",
    "vaul": "^1.1.2",
    "viem": "^2.47.0",
    "wagmi": "^3.5.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.3.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "esbuild-register": "^3.6.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
