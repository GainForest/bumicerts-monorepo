{
  "name": "@gainforest/atproto-mutations-next",
  "version": "0.0.1",
  "description": "ATProto mutations for Next.js — server actions, server utilities, and typed client namespace.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./actions": {
      "source": "./src/actions/index.ts",
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js",
      "require": "./dist/actions.cjs"
    },
    "./server": {
      "source": "./src/server/index.ts",
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "source": "./src/client/index.ts",
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "actions": ["dist/actions.d.ts"],
      "server": ["dist/server.d.ts"],
      "client": ["dist/client.d.ts"]
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/api": "0.19.0",
    "@gainforest/atproto-auth-next": "workspace:*",
    "@gainforest/atproto-mutations-core": "workspace:*",
    "@gainforest/internal-utils": "workspace:*",
    "effect": "^3.19.19"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
