# ============================================================
# TAP SERVICE ENVIRONMENT VARIABLES (Template)
# ============================================================
# This file documents all env vars for the Tap service.
# The actual values are in tap.env.railway and are synced to
# Railway automatically via GitHub Actions on each deploy.
#
# RULES:
#   - Static values (like LOG_LEVEL, PORT) → add to tap.env.railway
#   - Secrets (passwords, tokens) → set once in Railway UI using
#     Railway's secret() function: ${{secret(32)}}
#   - Cross-service references → set once in Railway UI using
#     Railway reference syntax: ${{ServiceName.VARIABLE}}
#
# The GitHub Action skips any line containing ${{ }} so those
# are never overwritten by the automated sync.
# ============================================================

# Port for Railway healthcheck - MUST match TAP_BIND port
# Without this, Railway's healthcheck will fail with "service unavailable"
PORT=2480

# Database - Tap uses SQLite, stored on a Railway volume at /data
TAP_DATABASE_URL=sqlite:///data/tap.db

# Server binding address
TAP_BIND=:2480

# AT Protocol relay URL - source of the firehose
TAP_RELAY_URL=https://bsky.network

# Signal collection - auto-discover DIDs that publish this collection type
TAP_SIGNAL_COLLECTION=org.hypercerts.claim.activity

# Collection filters - which AT Proto collections to sync from the relay
# NOTE: This value is auto-generated and overwritten by the GitHub Action
# based on the indexed collections in the indexer. Do not set manually.
TAP_COLLECTION_FILTERS=app.bumicerts.*,app.certified.*,app.gainforest.*,org.hyperboards.*,org.hypercerts.*,org.impactindexer.*

# Whether Tap sends ACKs back to the relay for processed events
TAP_DISABLE_ACKS=false

# Keep replay enabled in production so Tap resumes from saved firehose cursor
TAP_NO_REPLAY=false

# Log verbosity: debug | info | warn | error
TAP_LOG_LEVEL=info

# ============================================================
# MANUAL SETUP REQUIRED (set once in Railway UI, never synced)
# ============================================================
#
# TAP_ADMIN_PASSWORD=${{secret(32)}}
#   → Railway UI: Variables tab → New Variable → name TAP_ADMIN_PASSWORD
#     → click "Generate" or paste ${{secret(32)}}
