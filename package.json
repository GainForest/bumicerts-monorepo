{
  "name": "atproto-packages",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "GENERATED"
  ],
  "scripts": {
    "build": "bun run --filter '@gainforest/internal-utils' --filter '@gainforest/atproto-mutations-core' --filter '@gainforest/atproto-auth-next' --filter '@gainforest/leaflet-react' build && bun run --filter '@gainforest/atproto-mutations-next' build",
    "dev": "bun run --filter '@gainforest/*' dev",
    "clean": "rm -rf packages/*/dist",
    "fetch-lexicons": "./GENERATED/scripts/fetch-lexicons.sh",
    "fetch-lexicons:local": "./GENERATED/scripts/fetch-lexicons.sh -gl ../lexicons -hl ../hypercerts-lexicon",
    "gen:types": "bun run GENERATED/scripts/codegen.ts",
    "gen:indexer": "bun run GENERATED/scripts/generate-collections.ts && bun run --cwd apps/indexer sync:filters",
    "gen:resolvers": "bun run GENERATED/scripts/generate-resolvers.ts",
    "codegen": "bun run fetch-lexicons && bun run gen:types && bun run gen:indexer && bun run gen:resolvers",
    "codegen:local": "bun run fetch-lexicons:local && bun run gen:types && bun run gen:indexer && bun run gen:resolvers",
    "indexer:dev": "bun run --cwd apps/indexer dev",
    "indexer:start": "bun run --cwd apps/indexer start",
    "indexer:setup": "bun run --cwd apps/indexer setup",
    "indexer:migrate": "bun run --cwd apps/indexer db:migrate",
    "indexer:docker:up": "bun run --cwd apps/indexer docker:up",
    "indexer:docker:down": "bun run --cwd apps/indexer docker:down",
    "indexer:docker:reset": "bun run --cwd apps/indexer docker:reset",
    "indexer:typecheck": "bun run --cwd apps/indexer typecheck",
    "bumicerts:dev": "bun run --cwd apps/bumicerts-platform dev",
    "bumicerts:build": "bun run --cwd apps/bumicerts-platform build",
    "bumicerts:vercel-build": "bun run gen:types && bun run build && bun run --cwd apps/bumicerts-platform build",
    "bumicerts:start": "bun run --cwd apps/bumicerts-platform start",
    "bumicerts:typecheck": "bun run --cwd apps/bumicerts-platform typecheck",
    "bumicerts:lint": "bun run --cwd apps/bumicerts-platform lint",
    "docs:dev": "bun run --cwd apps/bumicerts-docs dev",
    "docs:build": "bun run --cwd apps/bumicerts-docs build",
    "docs:start": "bun run --cwd apps/bumicerts-docs start",
    "docs:typecheck": "bun run --cwd apps/bumicerts-docs typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@atproto/lex": "^0.0.19",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "^1.2.7",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
