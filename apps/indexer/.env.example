# GainForest AT Protocol Indexer — Environment Configuration
# Copy to .env and fill in the values.

# ============================================================
# DATABASE (required)
# ============================================================
DATABASE_URL=postgres://gainforest:gainforest@localhost:5432/gainforest_indexer

# ============================================================
# TAP SYNC SERVICE
# ============================================================

# Tap server URL.
# Use http://localhost:2480 when running the indexer directly on the host (bun run dev).
# Use http://tap:2480 when running the indexer inside Docker alongside the Tap container.
TAP_URL=http://localhost:2480

# Admin password for Tap API (required for adding/removing repos)
TAP_ADMIN_PASSWORD=your-secure-password-here

# ============================================================
# SEED DIDS (optional)
# Known GainForest organization DIDs to track on startup.
# Comma-separated list. These are added via Tap API on boot.
# ============================================================
SEED_DIDS=

# ============================================================
# SEED PDSS (optional)
# PDS hosts to crawl on startup via com.atproto.sync.listRepos.
# All active DIDs found on these hosts are added to Tap for
# backfill and live tracking. Combined with SEED_DIDS (deduplicated).
# Comma-separated list of host URLs (with or without https://).
# Example: SEED_PDSS=https://climateai.org,https://bsky.social
# ============================================================
SEED_PDSS=

# Max events to buffer before flushing to DB.
# Lower = more DB round-trips but lower latency. Higher = fewer trips.
BATCH_SIZE=100

# Max milliseconds to wait before flushing, even if BATCH_SIZE not reached.
BATCH_TIMEOUT_MS=5000

# ============================================================
# PDS HOST CACHE
# ============================================================

# In-memory TTL (seconds) for DID → PDS host mappings.
# Hosts are also persisted to the database permanently. This TTL only
# controls how long a mapping lives in the in-process LRU cache before
# the DB is consulted again. The DB cache has no TTL of its own — entries
# are kept indefinitely (PDS migrations are rare).
#
# Higher value  = fewer DB lookups, slower to reflect PDS migrations.
# Lower value   = more DB lookups, faster to reflect PDS migrations.
# Default: 3600 (1 hour)
PDS_HOST_CACHE_TTL_SECONDS=3600

# ============================================================
# VALIDATION
# ============================================================

# Validate incoming records with Zod schemas before storing.
# Set to "false" to disable for maximum throughput.
VALIDATE_RECORDS=true

# Log validation errors to the console.
# Set to "false" to suppress all validation error logs (e.g. to reduce noise
# during backfill when many legacy records are expected to fail).
# Default: true
LOG_VALIDATION_ERRORS=true

# When LOG_VALIDATION_ERRORS=false, selectively re-enable logging for specific
# collections. Comma-separated list of collection NSIDs. Has no effect when
# LOG_VALIDATION_ERRORS=true.
# Example: LOG_VALIDATION_FILTER=app.gainforest.organization.info,org.hypercerts.claim.activity
LOG_VALIDATION_FILTER=

# ============================================================
# SERVERS
# ============================================================

# Health check server port (liveness/readiness probes).
HEALTH_PORT=4001

# GraphQL API port.
GRAPHQL_PORT=4000
HOST=0.0.0.0

# ============================================================
# LABELLER (Hyperlabel)
# ============================================================

# Hyperlabel labeller service base URL
HYPERLABEL_URL=https://hyperlabel-production.up.railway.app

# Hyperlabel labeller DID
HYPERLABEL_DID=did:plc:5rw6of6lry7ihmyhm323ycwn

# ============================================================
# LOGGING
# ============================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info
